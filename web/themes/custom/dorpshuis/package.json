{
  "name": "dorpshuis",
  "version": "1.0.0",
  "description": "Dorpshuis Drupal theme – Atomic Design + Tailwind CSS",
  "private": true,
  "volta": {
    "node": "20.19.0",
    "npm": "10.9.2"
  },
  "scripts": {
    "tailwind:build": "tailwindcss -i css/input.css -o dist/css/tailwind.css --minify",
    "tailwind:watch": "tailwindcss -i css/input.css -o dist/css/tailwind.css --watch",
    "sass:build": "sass css/main.scss dist/css/main.css --style=compressed --no-source-map",
    "sass:watch": "sass css/main.scss dist/css/main.css --watch",
    "build": "npm run tailwind:build && npm run sass:build",
    "watch": "concurrently \"npm run tailwind:watch\" \"npm run sass:watch\"",
    "lint:js": "eslint js/**/*.js patterns/**/*.js",
    "lint:scss": "stylelint \"css/**/*.scss\" \"patterns/**/*.scss\"",
    "lint:fix": "eslint js/**/*.js patterns/**/*.js --fix && stylelint \"css/**/*.scss\" \"patterns/**/*.scss\" --fix",
    "format": "prettier --write \"**/*.{js,scss,twig,json,yml}\""
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "sass": "^1.85.1",
    "stylelint": "^16.14.1",
    "stylelint-config-standard-scss": "^14.0.0",
    "tailwindcss": "^3.4.17"
  }
}
