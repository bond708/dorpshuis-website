{#
  Organism: Agenda + Nieuws — 2 kolommen
  Variabelen:
    - agenda (render array): Drupal View agenda
    - news (render array): Drupal View nieuws
#}
<section class="o-agenda-news bg-white py-16">
  <div class="max-w-content mx-auto px-6 grid md:grid-cols-2 gap-12">
    <div class="o-agenda-news__agenda">
      {{ agenda }}
    </div>
    <div class="o-agenda-news__news">
      {{ news }}
    </div>
  </div>
</section>
