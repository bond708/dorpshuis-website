{#
  Organism: Site Footer
  Variabelen:
    - footer_first..footer_third (render arrays)
    - footer_bottom (render array)
    - site_name (string)

  Gebruik:
    footer_first  → Contactgegevens blok (regio Footer first)
    footer_second → Webform 'contact' blok (regio Footer second)
#}
<footer class="o-footer bg-primary-600 text-white mt-auto" role="contentinfo">

  <div class="o-footer__main">
    <div class="max-w-content mx-auto px-6 py-12 grid gap-12 md:grid-cols-2">

      {# Links: adres + kaart #}
      <div class="o-footer__col">

        {{ footer_first }}

        <div class="o-footer__map mt-6 rounded-lg overflow-hidden h-48">
          <iframe
            title="{{ 'Locatie Dorpshuis Borgercompagnie'|t }}"
            src="https://maps.google.com/maps?q=Borgercompagnie+204A,+9631+TN+Borgercompagnie&output=embed&z=15"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>

        <a
          href="https://maps.google.com/?q=Borgercompagnie+204A,+9631+TN+Borgercompagnie"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-3 text-sm text-accent-400 hover:text-white transition-colors no-underline"
          aria-label="{{ 'Route plannen naar Dorpshuis Borgercompagnie (opent in nieuw tabblad)'|t }}"
        >
          {{ 'Route plannen →'|t }}
        </a>

      </div>

      {# Rechts: contactformulier (webform blok in regio footer_second) #}
      <div class="o-footer__col o-footer__form">

        {{ footer_second }}

        {% if footer_third %}
          {{ footer_third }}
        {% endif %}

      </div>

    </div>
  </div>

  <div class="o-footer__bottom border-t border-white/10">
    <div class="max-w-content mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-white/50">
      {{ footer_bottom }}
    </div>
  </div>

</footer>
